        "@fastify/swagger-ui": "^5.2.5",
        "@prisma/client": "^6.6.0",
        "dotenv": "^16.4.7",
        "fastify": "^5.2.1",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/node": "^22.13.10",
        "prisma": "^6.6.0",
        "tsx": "^4.19.3",
        "typescript": "^5.8.2",
        "vitest": "^3.0.8"
    }
